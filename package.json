{
  "name": "tcgplayer-automation-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-host-start.mjs",
    "dev:docker": "docker compose up --build",
    "dev:host": "node scripts/dev-host-start.mjs",
    "dev:app": "node scripts/run-with-node-options.mjs react-router dev",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "dev:db": "docker compose exec postgres psql -U postgres -d tcgplayer_automation",
    "dev:db:refresh": "node scripts/dev-db-refresh.mjs",
    "test": "tsx app/features/inventory-management/components/quantityKeyboard.test.ts",
    "build": "node scripts/run-with-node-options.mjs react-router build",
    "start": "node scripts/run-with-node-options.mjs react-router-serve ./build/server/index.js",
    "typecheck": "node scripts/run-with-node-options.mjs react-router typegen && node scripts/run-with-node-options.mjs tsc",
    "db:migrate": "node scripts/db-migrate.mjs",
    "prod:deploy": "node scripts/prod.mjs deploy",
    "prod:update": "node scripts/prod.mjs update",
    "prod:start": "node scripts/prod.mjs start",
    "prod:stop": "node scripts/prod.mjs stop",
    "prod:restart": "node scripts/prod.mjs restart",
    "prod:logs": "node scripts/prod.mjs logs",
    "prod:status": "node scripts/prod.mjs status",
    "prod:shell": "node scripts/prod.mjs shell",
    "prod:clean": "node scripts/prod.mjs clean"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.1.1",
    "@mui/x-data-grid": "^8.8.0",
    "@react-router/node": "^7.5.3",
    "@react-router/serve": "^7.5.3",
    "axios": "^1.9.0",
    "date-fns": "^4.1.0",
    "isbot": "^5.1.27",
    "ml-levenberg-marquardt": "^5.0.0",
    "p-limit": "^6.2.0",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.3"
  },
  "devDependencies": {
    "@react-router/dev": "^7.5.3",
    "@types/date-fns": "^2.6.3",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.16",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
